.env

# Build artifacts. The bundle (dist/camera-gallery-card.js) lives on main
# only — sync-bundle.yml (re)builds and force-commits it after every push,
# and release.yml does the same on the release PR's branch. Contributors
# never commit it themselves, which is why the path is gitignored here:
# it makes accidental dist commits (and their resulting merge conflicts)
# impossible on PR branches. The bot bypasses the ignore via `git add -f`.
# HACS still serves the file from the repo (hacs.json: content_in_root: false).
dist/

# Tooling caches
*.tsbuildinfo
.eslintcache

# Test coverage reports
coverage/

# Local-only contributor docs (not part of upstream)
CLAUDE.md
plans/
